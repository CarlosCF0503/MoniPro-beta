// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums (Status e Tipos)
enum TipoUsuario {
  aluno
  monitor
}

enum StatusMonitoria {
  ativa
  pendente
  realizada
  concluida
  cancelada
}

enum StatusAgendamento {
  pendente
  confirmado
  cancelado
}

// Tabelas
model Usuario {
  id            Int         @id @default(autoincrement())
  nome_completo String
  email         String     
  senha         String
  tipo_usuario  TipoUsuario
  matricula     Int         

  // Relacionamentos: O Prisma entende quem cria vagas e quem se inscreve nelas
  // AJUSTE: Alterado de MonitoriaService para Monitoria
  monitorias_criadas Monitoria[]   @relation("MonitorParaMonitoria")
  meus_agendamentos  Agendamento[] @relation("AlunoParaAgendamento")

// Garante que não existam dois "alunos" com o mesmo e-mail, mas permite 1 aluno e 1 monitor.
  @@unique([email, tipo_usuario]) 
  // Garante o mesmo bloqueio para a matrícula (já que no sistema da faculdade a matrícula é única por cargo)
  @@unique([matricula, tipo_usuario])

  @@map("usuarios") // Nome exato da tabela no Postgres
}

model Disciplina {
  id         Int         @id @default(autoincrement())
  nome       String
  // AJUSTE: Alterado de MonitoriaService para Monitoria
  monitorias Monitoria[]

  @@map("disciplinas")
}

// AJUSTE: Nome do modelo alterado de MonitoriaService para Monitoria
model Monitoria {
  id        Int             @id @default(autoincrement())
  horario   DateTime
  descricao String?
  local     String
  status    StatusMonitoria @default(ativa)

  // Chaves Estrangeiras
  id_monitor Int
  monitor    Usuario @relation("MonitorParaMonitoria", fields: [id_monitor], references: [id])

  id_disciplina Int
  disciplina    Disciplina @relation(fields: [id_disciplina], references: [id])

  inscricoes Agendamento[]

  @@map("monitorias")
}

model Agendamento {
  id        Int               @id @default(autoincrement())
  data_hora DateTime
  status    StatusAgendamento @default(pendente)

  // Chaves Estrangeiras
  id_monitoria Int
  // AJUSTE: Alterado de MonitoriaService para Monitoria
  monitoria    Monitoria @relation(fields: [id_monitoria], references: [id])

  id_aluno Int
  aluno    Usuario @relation("AlunoParaAgendamento", fields: [id_aluno], references: [id])

  @@map("agendamentos")
}
